{
  "name": "@n123999/spirit-agent-extension-system-message-demo",
  "version": "0.1.0",
  "description": "This is an extension example for having the AI output the system message.",
  "main": "dist/index.js",
  "type": "commonjs",
  "spiritExtension": {
    "schemaVersion": 1,
    "displayName": "System message demo",
    "supportedHosts": [
      "cli",
      "desktop"
    ],
    "requestedCapabilities": [
      "system-prompt"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/N123999/spirit-agent-extension-system-message-demo.git"
  },
  "keywords": [
    "spirit-agent",
    "extension",
    "system-prompt"
  ],
  "author": "n123999",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/N123999/spirit-agent-extension-system-message-demo/issues"
  },
  "homepage": "https://github.com/N123999/spirit-agent-extension-system-message-demo#readme",
  "devDependencies": {
    "@types/node": "^24.8.1",
    "typescript": "^5.9.3"
  }
}
